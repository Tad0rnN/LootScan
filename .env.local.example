# Supabase - get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini AI - get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Resend - used for wishlist alerts and newsletter emails
RESEND_API_KEY=your-resend-api-key-here
NEWSLETTER_FROM_EMAIL=LootScan <newsletter@yourdomain.com>

# Supabase server-side access for cron jobs and newsletter subscriptions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site + cron
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=yourtag-20
CRON_SECRET=your-random-cron-secret
